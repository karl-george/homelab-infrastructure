{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations and alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Centralised production and staging logs from the DevOps home lab.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "loki",
        "uid": "{{ grafana_loki_datasource_uid }}"
      },
      "description": "Number of log entries over time, grouped by service.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Log entries",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [
            "sum"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "{{ grafana_version }}",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "{{ grafana_loki_datasource_uid }}"
          },
          "editorMode": "code",
          "expr": "sum by (service) (count_over_time({environment=~\"${environment:regex}\", host=~\"${host:regex}\", service=~\"${service:regex}\"}[$__auto]))",
          "legendFormat": "{{ "{{" }}service{{ "}}" }}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log Volume by Service",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "{{ grafana_loki_datasource_uid }}"
      },
      "description": "Nginx requests grouped by their HTTP response status.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "sum"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "{{ grafana_version }}",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "{{ grafana_loki_datasource_uid }}"
          },
          "editorMode": "code",
          "expr": "sum by (status) (count_over_time({environment=~\"${environment:regex}\", host=~\"${host:regex}\", service=\"nginx-access\"} | pattern `<remote_addr> - <remote_user> [<time_local>] \"<method> <request_uri> <protocol>\" <status> <body_bytes_sent> \"<http_referer>\" \"<http_user_agent>\"` | status != \"\" [$__range]))",
          "legendFormat": "HTTP {{ "{{" }}status{{ "}}" }}",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "HTTP Responses by Status",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "{{ grafana_loki_datasource_uid }}"
      },
      "description": "Recent Nginx requests returning HTTP 4xx or 5xx status codes.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 3,
      "options": {
        "dedupStrategy": "none",
        "enableInfiniteScrolling": false,
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "{{ grafana_version }}",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "{{ grafana_loki_datasource_uid }}"
          },
          "editorMode": "code",
          "expr": "{environment=~\"${environment:regex}\", host=~\"${host:regex}\", service=\"nginx-access\"} | pattern `<remote_addr> - <remote_user> [<time_local>] \"<method> <request_uri> <protocol>\" <status> <body_bytes_sent> \"<http_referer>\" \"<http_user_agent>\"` | status =~ \"4..|5..\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent HTTP Errors",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "{{ grafana_loki_datasource_uid }}"
      },
      "description": "All logs matching the selected environment, host, service and search text.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 13,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 4,
      "options": {
        "dedupStrategy": "none",
        "enableInfiniteScrolling": false,
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "{{ grafana_version }}",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "{{ grafana_loki_datasource_uid }}"
          },
          "editorMode": "code",
          "expr": "{environment=~\"${environment:regex}\", host=~\"${host:regex}\", service=~\"${service:regex}\"} |= \"$search\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "All Logs",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "{{ grafana_loki_datasource_uid }}"
      },
      "description": "Log lines containing common error or failure terms.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "id": 5,
      "options": {
        "dedupStrategy": "none",
        "enableInfiniteScrolling": false,
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "{{ grafana_version }}",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "{{ grafana_loki_datasource_uid }}"
          },
          "editorMode": "code",
          "expr": "{environment=~\"${environment:regex}\", host=~\"${host:regex}\", service=~\"${service:regex}\"} |~ \"(?i)error|failed|failure|exception|critical\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Errors and Failures",
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 41,
  "tags": [
    "logging",
    "loki",
    "home-lab"
  ],
