{
  "uid": "{{ grafana_infrastructure_dashboard_uid }}",
  "title": "{{ grafana_infrastructure_dashboard_title }}",
  "timezone": "browser",
  "schemaVersion": 41,
  "version": 1,

  "editable": false,

  "refresh": "15s",

  "time": {
  "from": "now-6h",
  "to": "now"
},

"timepicker": {
  "refresh_intervals": [
    "5s",
    "10s",
    "15s",
    "30s",
    "1m",
    "5m",
    "15m",
    "30m",
    "1h"
  ],

  "time_options": [
    "5m",
    "15m",
    "30m",
    "1h",
    "3h",
    "6h",
    "12h",
    "24h",
    "2d",
    "7d",
    "30d"
  ]
},

  "tags": [
    "infrastructure",
    "prometheus",
    "node-exporter"
  ],

  "annotations": {
  "list": [
    {
      "builtIn": 1,

      "datasource": {
        "type": "grafana",
        "uid": "-- Grafana --"
      },

      "enable": true,

      "hide": true,

      "iconColor": "rgba(0, 211, 255, 1)",

      "name": "Annotations & Alerts",

      "type": "dashboard"
    }
  ]
},

"links": [
  {
    "asDropdown": false,
    "icon": "external link",
    "includeVars": false,
    "keepTime": true,
    "tags": [],
    "targetBlank": true,
    "title": "Prometheus Targets",
    "tooltip": "Open the Prometheus target health page.",
    "type": "link",
    "url": "http://{{ monitoring_bind_address }}:{{ prometheus_http_port }}/targets"
  },
  {
    "asDropdown": false,
    "icon": "external link",
    "includeVars": false,
    "keepTime": true,
    "tags": [],
    "targetBlank": true,
    "title": "Prometheus Query",
    "tooltip": "Open the Prometheus expression browser.",
    "type": "link",
    "url": "http://{{ monitoring_bind_address }}:{{ prometheus_http_port }}/query"
  }
],

  "templating": {
    "list": [
        {
            "name": "environment",
            "label": "Environment",
            "type": "custom",
            "hide": 0,
            "query": "production, staging",
            "current": {
                "text": "production",
                "value": "production"
            }
        },
        {
        "name": "host",
        "label": "Host",
        "type": "query",

        "datasource": {
            "type": "prometheus",
            "uid": "{{ grafana_prometheus_datasource_uid }}"
        },

        "definition": "label_values(node_uname_info, instance)",

        "query": {
            "query": "label_values(node_uname_info, instance)"
        },

        "refresh": 1,

        "sort": 1,

        "includeAll": false,

        "multi": false
        }
    ]
  },

  "panels": [
    {
        "id": 1,

        "title": "Host Availability",

        "type": "stat",

        "gridPos": {
            "h": 6,
            "w": 6,
            "x": 0,
            "y": 0
        },

        "datasource": {
            "type": "prometheus",
            "uid": "{{ grafana_prometheus_datasource_uid }}"
        },

        "targets": [
            {
            "expr": "up{instance=\"$host\"}",
            "refId": "A"
            }
        ],

        "options": {
            "reduceOptions": {
                "calcs": [
                    "lastNotNull"
                ]
            },

            "colorMode": "background",

            "graphMode": "none"
        },

        "fieldConfig": {
            "defaults": {
                "mappings": [
                    {
                        "type": "value",
                        "options": {
                            "1": {
                            "text": "UP"
                            },
                            "0": {
                            "text": "DOWN"
                            }
                        }
                    }
                ],

                "thresholds": {
                    "mode": "absolute",
                    "steps": [
                        {
                            "color": "red",
                            "value": null
                        },
                        {
                            "color": "green",
                            "value": 1
                        }
                    ]
                }
            }
        }
    },
    {
        "id": 2,

        "title": "CPU Utilisation",

        "type": "gauge",

        "gridPos": {
            "h": 9,
            "w": 9,
            "x": 6,
            "y": 0
        },

        "datasource": {
            "type": "prometheus",
            "uid": "{{ grafana_prometheus_datasource_uid }}"
        },

        "targets": [
            {
            "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",instance=\"$host\"}[5m])) * 100)",
            "refId": "A"
            }
        ],

        "fieldConfig": {
            "defaults": {

                "unit": "percent",

                "min": 0,

                "max": 100,

                "thresholds": {
                    "mode": "absolute",
                    "steps": [
                        {
                            "color": "green",
                            "value": null
                        },
                        {
                            "color": "yellow",
                            "value": 70
                        },
                        {
                            "color": "red",
                            "value": 90
                        }
                    ]
                }
            }
        }
    }, 
    {
        "id": 3,

        "title": "Memory Utilisation",

        "type": "gauge",

        "gridPos": {
            "h": 9,
            "w": 9,
            "x": 15,
            "y": 0
        },

        "datasource": {
            "type": "prometheus",
            "uid": "{{ grafana_prometheus_datasource_uid }}"
        },

        "targets": [
            {
            "expr": "(1 - (node_memory_MemAvailable_bytes{instance=\"$host\"} / node_memory_MemTotal_bytes{instance=\"$host\"})) * 100",
            "refId": "A"
            }
        ],

        "fieldConfig": {
            "defaults": {

            "unit": "percent",

            "min": 0,

            "max": 100,

            "thresholds": {
                    "mode": "absolute",
                    "steps": [
                        {
                            "color": "green",
                            "value": null
                        },
                        {
                            "color": "yellow",
                            "value": 75
                        },
                        {
                            "color": "red",
                            "value": 90
                        }
                    ]
                }
            }
        }
    },
    {
  "id": 4,

  "title": "Root Filesystem Utilisation",

  "description": "Percentage of the selected host's root filesystem currently in use.",

  "type": "gauge",

  "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 9
  },

  "datasource": {
    "type": "prometheus",
    "uid": "{{ grafana_prometheus_datasource_uid }}"
  },

  "targets": [
    {
      "expr": "100 * (1 - (node_filesystem_avail_bytes{instance=\"$host\",mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs|rootfs\"} / node_filesystem_size_bytes{instance=\"$host\",mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs|rootfs\"}))",
      "refId": "A"
    }
  ],

  "options": {
    "reduceOptions": {
      "values": false,
      "calcs": [
        "lastNotNull"
      ],
      "fields": ""
    },

    "orientation": "auto",

    "showThresholdLabels": false,

    "showThresholdMarkers": true
  },

  "fieldConfig": {
    "defaults": {
      "unit": "percent",

      "min": 0,

      "max": 100,

      "decimals": 1,

      "thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "green",
            "value": null
          },
          {
            "color": "yellow",
            "value": 75
          },
          {
            "color": "red",
            "value": 90
          }
        ]
      }
    },

    "overrides": []
  }
},
{
  "id": 5,

  "title": "System Uptime",

  "description": "Elapsed time since the selected host last booted.",

  "type": "stat",

  "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 9
  },

  "datasource": {
    "type": "prometheus",
    "uid": "{{ grafana_prometheus_datasource_uid }}"
  },

  "targets": [
    {
      "expr": "time() - node_boot_time_seconds{instance=\"$host\"}",
      "refId": "A"
    }
  ],

  "options": {
    "reduceOptions": {
      "values": false,
      "calcs": [
        "lastNotNull"
      ],
      "fields": ""
    },

    "orientation": "auto",

    "textMode": "value_and_name",

    "colorMode": "value",

    "graphMode": "area",

    "justifyMode": "auto",

    "wideLayout": true
  },

  "fieldConfig": {
    "defaults": {
      "unit": "s",

      "decimals": 0,

      "thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "green",
            "value": null
          }
        ]
      }
    },

    "overrides": []
  }
},
{
  "id": 6,

  "title": "Network Receive Rate",

  "description": "Inbound traffic received by the selected host, grouped by network interface.",

  "type": "timeseries",

  "gridPos": {
    "h": 9,
    "w": 24,
    "x": 0,
    "y": 17
  },

  "datasource": {
    "type": "prometheus",
    "uid": "{{ grafana_prometheus_datasource_uid }}"
  },

  "targets": [
    {
      "expr": "rate(node_network_receive_bytes_total{instance=\"$host\",device!~\"lo|veth.*|docker.*|br-.*\"}[5m])",
      "legendFormat": "{% raw %}{{device}}{% endraw %}",
      "refId": "A"
    }
  ],

  "options": {
    "tooltip": {
      "mode": "multi",
      "sort": "desc"
    },

    "legend": {
      "displayMode": "table",
      "placement": "bottom",
      "calcs": [
        "lastNotNull",
        "mean",
        "max"
      ]
    }
  },

  "fieldConfig": {
    "defaults": {
      "unit": "Bps",

      "custom": {
        "drawStyle": "line",
        "lineInterpolation": "linear",
        "lineWidth": 2,
        "fillOpacity": 15,
        "gradientMode": "none",
        "spanNulls": false,
        "showPoints": "never",
        "axisPlacement": "auto",
        "axisLabel": "",
        "scaleDistribution": {
          "type": "linear"
        }
      },

      "thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "green",
            "value": null
          }
        ]
      }
    },

    "overrides": []
  }
},
{
  "id": 7,

  "title": "Network Transmit Rate",

  "description": "Outbound traffic transmitted by the selected host, grouped by network interface.",

  "type": "timeseries",

  "gridPos": {
    "h": 9,
    "w": 24,
    "x": 0,
    "y": 26
  },

  "datasource": {
    "type": "prometheus",
    "uid": "{{ grafana_prometheus_datasource_uid }}"
  },

  "targets": [
    {
      "expr": "rate(node_network_transmit_bytes_total{instance=\"$host\",device!~\"lo|veth.*|docker.*|br-.*\"}[5m])",
      "legendFormat": "{% raw %}{{device}}{% endraw %}",
      "refId": "A"
    }
  ],

  "options": {
    "tooltip": {
      "mode": "multi",
      "sort": "desc"
    },

    "legend": {
      "displayMode": "table",
      "placement": "bottom",
      "calcs": [
        "lastNotNull",
        "mean",
        "max"
      ]
    }
  },

  "fieldConfig": {
    "defaults": {
      "unit": "Bps",

      "custom": {
        "drawStyle": "line",
        "lineInterpolation": "linear",
        "lineWidth": 2,
        "fillOpacity": 15,
        "gradientMode": "none",
        "spanNulls": false,
        "showPoints": "never",
        "axisPlacement": "auto",
        "axisLabel": "",
        "scaleDistribution": {
          "type": "linear"
        }
      },

      "thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "green",
            "value": null
          }
        ]
      }
    },

    "overrides": []
  }
}
  ]
}