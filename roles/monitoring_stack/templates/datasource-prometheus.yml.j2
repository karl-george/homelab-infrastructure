---
apiVersion: 1

deleteDatasources:
  - name: "{{ grafana_prometheus_datasource_name }}"
    orgId: 1

datasources:
  - name: "{{ grafana_prometheus_datasource_name }}"
    uid: "{{ grafana_prometheus_datasource_uid }}"
    type: prometheus
    access: proxy
    orgId: 1
    url: >-
      http://{{ prometheus_http_listen_address }}:{{
      prometheus_http_port }}
    isDefault: false
    editable: false

    jsonData:
      httpMethod: POST
      manageAlerts: true
      prometheusType: Prometheus
      prometheusVersion: "{{ prometheus_version }}"
      cacheLevel: High
      disableRecordingRules: false
      incrementalQuerying: true