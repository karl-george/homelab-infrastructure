---
apiVersion: 1

deleteDatasources:
  - name: "{{ grafana_loki_datasource_name }}"
    orgId: 1

datasources:
  - name: "{{ grafana_loki_datasource_name }}"
    uid: "{{ grafana_loki_datasource_uid }}"
    type: loki
    access: proxy
    orgId: 1
    url: "http://{{ monitoring_bind_address }}:{{ loki_http_port }}"
    isDefault: true
    editable: false

    jsonData:
      timeout: 60
      maxLines: 1000